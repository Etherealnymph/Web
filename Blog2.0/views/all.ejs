<!DOCTYPE html>
<html lang="zh-CN" style="font-size:100%">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= currentNickname ? currentNickname + "'s Blog" : "昵称's Blog" %></title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <script>/* apply server fontSize */(function(){try{document.documentElement.style.fontSize = '<%= (typeof fontSize !== "undefined" ? fontSize : "100%") %>'}catch(e){} })()</script>
</head>
<body class="<%= theme === 'light' ? 'light' : '' %>" data-brightness="<%= brightness %>" data-lang="<%= lang %>" data-fontsize="<%= fontSize || '100%' %>">
    <header class="site-header">
        <div class="left">
            <% if (currentUserId) { %>
                <a class="btn" href="/user/<%= currentUserId %>"><%= __('Home') %></a>
            <% } %>
            <%= currentNickname ? currentNickname + "'s Blog" : "昵称's Blog" %>
        </div>
        <div style="margin-top:8px" class="brand">
                <form action="/" method="GET" style="display:flex;gap:8px;justify-content:center;align-items:center">
                    <input name="q" placeholder="<%= __('Search') %>" value="<%= typeof query !== 'undefined' ? query : '' %>" style="padding:6px;border-radius:6px;border:1px solid #ddd;min-width:220px" />
                    <button class="btn" type="submit"><%= __('Search') %></button>
                </form>
        </div>
        <div class="right controls">
                <div class="top-actions">
                <a class="btn" href="/new"><%= __('New') %></a>
                <% if (currentUserRole === 'admin' || currentUserRole === 'superadmin') { %>
                    <a class="btn" href="/admin/users"><%= __('Admin') %></a>
                <% } %>
            </div>
            
        </div>
    </header>

    <main class="container">
        <% if (typeof searchResults !== 'undefined' && searchResults) { %>
            <h2><%= __('SearchResults') %></h2>
                        <% if (searchResults.length === 0) { %>
                            <div class="card empty"><%= __('NoResults') %></div>
            <% } %>
            <% searchResults.forEach(article => { %>
                <article class="card">
                    <div class="author-meta">
                        <% if (article.authorAvatar) { %>
                            <img class="author-avatar" src="<%= article.authorAvatar %>" alt="avatar">
                        <% } %>
                        <% if (article.authorRole === 'admin') { %>
                            <span class="role-badge admin"><%= __('Admin') %></span>
                        <% } else if (article.authorRole === 'superadmin') { %>
                            <span class="role-badge superadmin"><%= __('Superadmin') %></span>
                        <% } %>
                    </div>
                    <h2 style="display:flex;justify-content:space-between;align-items:center"><span><%= article.title %></span></h2>
                    <div class="meta"><%= __('Like') %>: <%= article.likesCount || 0 %> · <%= __('View') %>: <%= article.views || 0 %></div>
                    <div class="description"><%- article.renderedDescription %></div>
                    <div style="margin-top:8px"><a class="btn" href="/article/<%= article._id %>"><%= __('ReadMore') %></a></div>
                </article>
            <% }) %>
        <% } else { %>
            <div class="page-tabs">
                <div class="tabs-nav" role="tablist" aria-label="内容分区">
                    <button class="tab-btn active" data-target="recommended-section" role="tab" aria-selected="true"><%= __('Recommended') %></button>
                    <button class="tab-btn" data-target="blogs-section" role="tab" aria-selected="false"><%= __('Blog') %></button>
                    <button class="tab-btn" data-target="qna-section" role="tab" aria-selected="false"><%= __('QandA') %></button>
                </div>

                <div class="tabs-content">
                    <section id="recommended-section" class="tab-panel">
                        <h2><%= __('Recommended') %></h2>
                        <div>
                            <% (recommended||[]).forEach(article => { %>
                                <article class="card">
                                    <div class="author-meta">
                                        <% if (article.authorAvatar) { %>
                                            <img class="author-avatar" src="<%= article.authorAvatar %>" alt="avatar">
                                        <% } %>
                                        <% if (article.authorRole === 'admin') { %>
                                            <span class="role-badge admin"><%= __('Admin') %></span>
                                        <% } else if (article.authorRole === 'superadmin') { %>
                                            <span class="role-badge superadmin"><%= __('Superadmin') %></span>
                                        <% } %>
                                    </div>
                                    <h2><%= article.title %></h2>
                                    <div class="meta">by <a href="/user/<%= article.authorId %>"><%= article.authorNickname || __('Anonymous') %></a> · <%= new Date(article.createdAt).toLocaleString() %></div>
                                    <div class="description"><%- article.renderedDescription %></div>
                                    <div style="display:flex;gap:8px;margin-top:8px"><a class="btn" href="/article/<%= article._id %>"><%= __('ReadMore') %></a></div>
                                </article>
                            <% }) %>
                        </div>
                    </section>

                    <section id="blogs-section" class="tab-panel hidden">
                        <h2><%= __('Blog') %></h2>
                        <% (blogs||[]).forEach(article => { %>
                                <article class="card">
                                <div class="author-meta">
                                    <% if (article.authorAvatar) { %>
                                        <img class="author-avatar" src="<%= article.authorAvatar %>" alt="avatar">
                                    <% } %>
                                    <% if (article.authorRole === 'admin') { %>
                                                <span class="role-badge admin"><%= __('Admin') %></span>
                                            <% } else if (article.authorRole === 'superadmin') { %>
                                                <span class="role-badge superadmin"><%= __('Superadmin') %></span>
                                            <% } %>
                                </div>
                                <h2><%= article.title %></h2>
                                <div class="meta">by <a href="/user/<%= article.authorId %>"><%= article.authorNickname || __('Anonymous') %></a> · <%= new Date(article.createdAt).toLocaleString() %></div>
                                <div class="description"><%- article.renderedDescription %></div>
                                <div style="display:flex;gap:8px;margin-top:8px"><a class="btn" href="/article/<%= article._id %>"><%= __('ReadMore') %></a></div>
                            </article>
                        <% }) %>
                    </section>

                    <section id="qna-section" class="tab-panel hidden">
                        <h2><%= __('QandA') %></h2>
                        <% if (!(qna||[]).length) { %>
                          <div class="card empty"><%= __('NoQna') %></div>
                        <% } %>
                        <% (qna||[]).forEach(article => { %>
                            <article class="card">
                                <div class="author-meta">
                                    <% if (article.authorAvatar) { %>
                                        <img class="author-avatar" src="<%= article.authorAvatar %>" alt="avatar">
                                    <% } %>
                                    <% if (article.authorRole === 'admin') { %>
                                        <span class="role-badge admin"><%= __('Admin') %></span>
                                    <% } else if (article.authorRole === 'superadmin') { %>
                                        <span class="role-badge superadmin"><%= __('Superadmin') %></span>
                                    <% } %>
                                </div>
                                <h2><%= article.title %></h2>
                                <div class="meta">by <a href="/user/<%= article.authorId %>"><%= article.authorNickname || __('Anonymous') %></a> · <%= new Date(article.createdAt).toLocaleString() %></div>
                                <div class="description"><%- article.renderedDescription %></div>
                                <div style="display:flex;gap:8px;margin-top:8px"><a class="btn" href="/article/<%= article._id %>"><%= __('Answer') %></a></div>
                            </article>
                        <% }) %>
                    </section>
                </div>
            </div>
        <% } %>

        <script src="/js/all-tabs.js"></script>
    </main>

    <script src="/js/autofit.js"></script>
    <script>try{autofit({designWidth:375,divisor:10,maxWidth:1200})}catch(e){/* ignore */}</script>
    <script src="/js/three.min.js"></script>
    <script src="/js/three-bg.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>