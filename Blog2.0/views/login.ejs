<!doctype html>
<html style="font-size:100%">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <title><%= __('Login') %></title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <script>(function(){try{document.documentElement.style.fontSize = '<%= (typeof fontSize !== "undefined" ? fontSize : "100%") %>'}catch(e){} })()</script>
  </head>
  <body class="ready <%= theme === 'light' ? 'light' : '' %>" data-brightness="<%= brightness %>" data-lang="<%= lang %>" data-fontsize="<%= fontSize || '100%' %>">
    <div style="position:fixed;top:8px;right:12px;z-index:60">
      <a class="btn" href="/set-lang?lang=zh-CN"><%= __('Chinese') %></a>
      <a class="btn" href="/set-lang?lang=en-US" style="margin-left:6px"><%= __('English') %></a>
    </div>
    <div class="container">
      <div class="card">
        <h2><%= __('Login') %></h2>
        <% if (error) { %>
          <p class="empty"><%= error %></p>
        <% } %>
        <form method="post" action="/login">
          <label><%= __('Nickname') %></label>
          <input type="text" name="nickname" required>
          <br>
          <br>
          <label><%= __('Account') %></label>
          <input type="text" name="account" required>
          <br>
          <br>
          <label><%= __('Password') %></label>
          <input type="password" name="password" required>
          <br>
          <br>
          <div style="display:flex;gap:8px;align-items:center">
            <label>输入验证码</label>
            <div id="login-extra">
                <div id="captcha-area">
                  <input type="text" name="captcha" required placeholder="<%= __('CaptchaPlaceholder') %>">
                  <img src="/captcha" alt="captcha" style="height:40px;cursor:pointer" onclick="this.src='/captcha?ts='+Date.now()" title="点击刷新验证码">
                </div>
              <div id="email-area" style="display:none">
                <input type="email" name="email" placeholder="<%= __('EmailPlaceholder') %>">
                <button type="button" id="send-code" class="btn"><%= __('SendCode') %></button>
                  <input type="text" name="emailCode" placeholder="<%= __('EmailCodeInput') %>">
              </div>
            </div>
              <br>
              <button type="button" id="toggle-login-mode" class="btn" data-email-label="<%= __('ToggleToEmail') %>" data-captcha-label="<%= __('ToggleToCaptcha') %>"><%= __('OtherLogin') %></button>
          </div>
          <div style="margin-top:12px;display:flex;gap:8px;align-items:center">
            <button class="btn primary" type="submit"><%= __('Login') %></button>
            <a class="btn" href="/register"><%= __('Register') %></a>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
<!-- Load frontend scripts: bootstrap bundle, three.js, three-bg and theme -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/three.min.js"></script>
<script src="/js/three-bg.js"></script>
<script src="/js/theme.js"></script>
<script src="/js/auth.js"></script>
</attachment>
