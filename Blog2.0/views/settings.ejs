<!DOCTYPE html>
<html lang="zh-CN" style="font-size:100%">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <title><%= __('Settings') %></title>
  <link rel="stylesheet" href="/css/styles.css">
  <script>(function(){try{document.documentElement.style.fontSize = '<%= (typeof fontSize !== "undefined" ? fontSize : "100%") %>'}catch(e){} })()</script>
</head>
<body class="<%= theme === 'light' ? 'light' : '' %>" data-brightness="<%= brightness %>" data-lang="<%= lang %>" data-fontsize="<%= fontSize || '100%' %>">
  <header class="site-header">
    <div class="left"><a class="btn" href="/me"><%= __('Home') %></a></div>
    <div class="brand"><%= __('Settings') %></div>
    <div class="right controls">
      <a class="btn" href="/logout" style="margin-left:8px"><%= __('Logout') %></a>
    </div>
  </header>
  <main class="container">
    <div class="card">
      <h2><%= __('Theme') %></h2>
      <form id="ui-settings" action="/settings" method="POST">
        <div class="field">
          <label><%= __('Theme') %></label>
          <select name="theme">
            <option value="dark" <%= theme === 'dark' ? 'selected' : '' %>><%= __('Dark') %></option>
            <option value="light" <%= theme === 'light' ? 'selected' : '' %>><%= __('Light') %></option>
          </select>
        </div>
        <div class="field">
          <label><%= __('FontSize') %></label>
          <select name="fontSize" id="fontSizeSelect">
            <option value="90%" <%= fontSize === '90%' ? 'selected' : '' %>>90%</option>
            <option value="95%" <%= fontSize === '95%' ? 'selected' : '' %>>95%</option>
            <option value="100%" <%= fontSize === '100%' ? 'selected' : '' %>>100% (默认)</option>
            <option value="105%" <%= fontSize === '105%' ? 'selected' : '' %>>105%</option>
            <option value="110%" <%= fontSize === '110%' ? 'selected' : '' %>>110%</option>
            <option value="115%" <%= fontSize === '115%' ? 'selected' : '' %>>115%</option>
            <option value="120%" <%= fontSize === '120%' ? 'selected' : '' %>>120%</option>
          </select>
          <div id="fontPreview" style="margin-top:8px;padding:8px;border:1px dashed #ddd">
            <div style="font-weight:600;margin-bottom:6px"><%= __('Preview') %></div>
            <div id="previewText">The quick brown fox jumps over the lazy dog. 这是一段预览文本。</div>
          </div>
        </div>
        <div class="field">
          <label><%= __('Brightness') %></label>
          <input id="brightness" type="range" name="brightness" min="0.5" max="1.4" step="0.05" value="<%= brightness %>">
        </div>
        <div class="field">
          <label><%= __('Language') %></label>
          <select name="lang">
            <option value="zh-CN" <%= lang === 'zh-CN' ? 'selected' : '' %>><%= __('Chinese') %></option>
            <option value="en-US" <%= lang === 'en-US' ? 'selected' : '' %>><%= __('English') %></option>
          </select>
        </div>
        <div style="margin-top:8px"><button class="btn" type="submit"><%= __('SaveUISettings') %></button></div>
      </form>
    </div>

    <div class="card" style="margin-top:12px">
      <h2><%= __('AccountSettings') %></h2>
      <form action="/settings" method="POST">
        <input type="hidden" name="_section" value="account">
        <div class="field"><label><%= __('Nickname') %></label><input name="nickname" value="<%= currentNickname || '' %>"></div>
        <div class="field"><label><%= __('Account') %></label><input name="account" value="<%= currentAccount || '' %>"></div>
        <div class="field"><label><%= __('CurrentPassword') %></label><input name="currentPassword" type="password"></div>
        <div class="field"><label><%= __('NewPassword') %></label><input name="newPassword" type="password"></div>
        <div style="margin-top:8px"><button class="btn" type="submit"><%= __('SaveAccountSettings') %></button></div>
      </form>
    </div>

  </main>
  <script src="/js/settings.js"></script>
  <script src="/js/three.min.js"></script>
  <script src="/js/three-bg.js"></script>
  <script src="/js/theme.js"></script>
</body>
</html>
